{
    "expo": {
        "name": "Polier",
        "slug": "polier",
        "version": "1.0.0",
        "runtimeVersion": {
            "policy": "sdkVersion"
        },
        "orientation": "portrait",
        "icon": "../../assets/images/icon.png",
        "scheme": "polier",
        "userInterfaceStyle": "light",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true,
            "infoPlist": {
                "ITSAppUsesNonExemptEncryption": false
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "../../assets/images/adaptive-icon.png",
                "backgroundColor": "#FFFFFF"
            }
        },
        "web": {
            "bundler": "metro",
            "output": "single",
            "favicon": "../../assets/images/icon.png"
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "../../assets/images/splash-icon.png",
                    "imageWidth": 180,
                    "resizeMode": "contain",
                    "backgroundColor": "#FFFFFF"
                }
            ],
            [
                "expo-notifications",
                {
                    "icon": "../../assets/images/icon.png",
                    "color": "#0A0A0A"
                }
            ],
            "expo-secure-store",
            "expo-font",
            "expo-web-browser"
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}
